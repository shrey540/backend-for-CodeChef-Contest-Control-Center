# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection URL (update user, password, host, port, and db name)
DATABASE_URL="postgresql://postgres:password@localhost:5432/codechef_ccc?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long, random secret in production (e.g. openssl rand -hex 64)
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="24h"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
